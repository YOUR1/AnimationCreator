# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/animationcreator

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# fal.ai API key - get from https://fal.ai/dashboard/keys
FAL_KEY=your_fal_api_key_here

# DigitalOcean Spaces / S3-compatible storage
STORAGE_ACCESS_KEY=your_spaces_access_key
STORAGE_SECRET_KEY=your_spaces_secret_key
STORAGE_BUCKET_NAME=animation-creator-assets
STORAGE_REGION=nyc3
STORAGE_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com

# CDN Configuration (optional)
CDN_ENABLED=true
CDN_URL=https://your-cdn.example.com

# Storage limits
MAX_UPLOAD_SIZE_MB=100

# Signed URL expiration (seconds)
DEFAULT_SIGNED_URL_EXPIRATION=3600
UPLOAD_URL_EXPIRATION=900

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=Ov23litRU8hn2BZHvEXq
GITHUB_CLIENT_SECRET=5160a3183cf793061363f9d97487adeb1ebf9735
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Frontend URL (for OAuth callbacks)
FRONTEND_URL=http://localhost:3000

# Sentry (error tracking - optional)
SENTRY_DSN=
